{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "isolatedModules": true,
    "types": ["node", "jest"]
  },
  "include": ["./src/**/*.ts", "./__tests__/**/*.ts", "./types/**/*.d.ts"],
  "exclude": ["./dist", "./node_modules", "./coverage"]
}
